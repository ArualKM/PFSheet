# ----------------------------------------------------------------------------
# PathForge environment variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# In production, set these in the Vercel project settings.
# ----------------------------------------------------------------------------

# Supabase project URL, e.g. https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable key (client-safe). New format: sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase secret key (server-only, full access). New format: sb_secret_...
# Equivalent to the legacy service_role key. NEVER expose to the client.
SUPABASE_SECRET_KEY=

# Public base URL of the app (used for share links, OpenGraph, redirects).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only pepper mixed into API-key hashing. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
PATHFORGE_API_KEY_PEPPER=
